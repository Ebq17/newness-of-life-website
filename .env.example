# Admin/API Server
PORT=3001

# Resend (Contact Form)
# Important: set this in your deployment environment (do NOT commit .env)
# For local tests, copy this file to .env and add the same RESEND_API_KEY
# that is configured in Netlify. Keep CONTACT_RESEND_API_KEY empty unless
# the contact form should intentionally use a different Resend key.
RESEND_API_KEY=
CONTACT_RESEND_API_KEY= # optional override for contact function
CHURCH_EMAIL="newnessoflife@clgi.org"
TO_EMAIL="newnessoflife@clgi.org" # legacy fallback
FROM_EMAIL="Newness of Life <kontakt@newnessoflife.de>"
NOREPLY_EMAIL="Newness of Life <noreply@newnessoflife.de>"

# Optional contact-specific overrides
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_NOREPLY_EMAIL=
CONTACT_ATTACH_PDF=0

# Optional donation-specific overrides
DONATION_TO_EMAIL=
DONATION_FROM_EMAIL=
DONATION_NOREPLY_EMAIL=

# For local testing without sending emails:
# DISABLE_EMAIL=1
